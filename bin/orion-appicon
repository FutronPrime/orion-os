#!/usr/bin/env python3
"""orion-appicon — set a macOS app/file icon from a PNG WITHOUT smushing it.
Preserves aspect ratio by padding the logo into a transparent square canvas (never stretch).
This is the programmatic equivalent of the macOS Get-Info paste method. Usage:
  orion-appicon <logo.png> <target.app-or-file>"""
import sys, os, subprocess, tempfile
from PIL import Image

def main():
    logo, target = sys.argv[1], sys.argv[2]
    src = Image.open(logo).convert("RGBA")
    with tempfile.TemporaryDirectory() as td:
        iconset = os.path.join(td, "icon.iconset"); os.makedirs(iconset)
        for base in (16, 32, 128, 256, 512):
            for scale, suffix in ((1, ""), (2, "@2x")):
                S = base * scale
                canvas = Image.new("RGBA", (S, S), (0, 0, 0, 0))   # transparent square
                im = src.copy()
                im.thumbnail((S, S), Image.LANCZOS)                # ASPECT-PRESERVING, no stretch
                canvas.paste(im, ((S - im.width)//2, (S - im.height)//2), im)
                canvas.save(os.path.join(iconset, f"icon_{base}x{base}{suffix}.png"))
        icns = os.path.join(td, "out.icns")
        subprocess.run(["iconutil", "-c", "icns", iconset, "-o", icns], check=True)
        # apply via macOS Cocoa NSWorkspace.setIcon (preserves as custom icon, like Get-Info paste)
        script = f'''
use framework "AppKit"
set img to current application's NSImage's alloc()'s initWithContentsOfFile:"{icns}"
current application's NSWorkspace's sharedWorkspace()'s setIcon:img forFile:"{os.path.abspath(target)}" options:0
'''
        subprocess.run(["osascript", "-l", "JavaScript", "-e",
                        "ObjC.import('AppKit');"
                        f"var img=$.NSImage.alloc.initWithContentsOfFile('{icns}');"
                        f"$.NSWorkspace.sharedWorkspace.setIconForFileOptions(img,'{os.path.abspath(target)}',0);"],
                       capture_output=True)
        # also drop the icns into an .app bundle if target is one
        if target.endswith(".app"):
            res = os.path.join(target, "Contents", "Resources")
            os.makedirs(res, exist_ok=True)
            subprocess.run(["cp", icns, os.path.join(res, "appicon.icns")])
    print(f"icon applied (aspect-preserved, not stretched): {target}")

if __name__ == "__main__":
    main()
